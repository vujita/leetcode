{
  "name": "nix-clap",
  "version": "2.4.5",
  "description": "Simple, lightweight, flexible, and comprehensive Command Line Argument Parsing for node.js",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "types": "dist-cjs/index.d.ts",
  "main": "dist-cjs/index.cjs",
  "module": "dist-esm/index.js",
  "exports": {
    ".": {
      "import": "./dist-esm/index.js",
      "require": "./dist-cjs/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "tag": "next"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchip/nix-clap.git"
  },
  "files": [
    "dist-cjs",
    "dist-esm",
    "examples"
  ],
  "keywords": [
    "unix",
    "un*x",
    "clap",
    "lightweight",
    "command",
    "line",
    "argument",
    "arguments",
    "parsing",
    "cli",
    "yargs",
    "argparse",
    "commander",
    "optimist"
  ],
  "author": "Joel Chen <joel123@gmail.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "scripts": {
    "postpack": "publish-util-postpack"
  }
}
